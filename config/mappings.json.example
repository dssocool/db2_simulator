  "auth": {
    "requirePassword": true,
    "caseInsensitiveUser": true,
    "users": [
      { "user": "db2inst1", "password": "YourStrongPassword123" }
    ]
  },
  "trace": {
    "logCommands": true,
    "hexDump": true
  },
  "matching": {
    "ignoreCase": true,
    "collapseWhitespace": true,
    "trimTrailingSemicolon": true
  },
  "mappings": [
    {
      "sql": "SELECT CURRENT TIMESTAMP AS TS FROM SYSIBM.SYSDUMMY1",
      "match": "exact",
      "result": {
        "columns": [
          { "name": "TS", "type": "TIMESTAMP", "nullable": true }
        ],
        "rows": [
          ["2026-06-10-14.30.00.000000"]
        ]
      }
    },
    {
      "sql": "SELECT 1 FROM SYSIBM.SYSDUMMY1",
      "match": "exact",
      "result": {
        "columns": [
          { "name": "1", "type": "INTEGER", "nullable": false }
        ],
        "rows": [
          [1]
        ]
      }
    },
    {
      "sql": "VALUES CURRENT SCHEMA",
      "match": "exact",
      "result": {
        "columns": [
          { "name": "1", "type": "VARCHAR", "length": 128, "nullable": false }
        ],
        "rows": [
          ["DB2INST1"]
        ]
      }
    },
    {
      "sql": "^SELECT \\* FROM DEMO\\b",
      "match": "regex",
      "result": {
        "columns": [
          { "name": "ID", "type": "INTEGER", "nullable": false },
          { "name": "NAME", "type": "VARCHAR", "length": 50, "nullable": true },
          { "name": "PRICE", "type": "DECIMAL", "precision": 9, "scale": 2, "nullable": true },
          { "name": "CREATED", "type": "TIMESTAMP", "nullable": true }
        ],
        "rows": [
          [1, "Widget", "19.99", "2026-01-15-09.00.00.000000"],
          [2, "Gadget", "5.50", "2026-02-20-10.30.00.000000"],
          [3, null, null, null]
        ]
      }
    }
  ],
  "defaultResponse": {
    "error": {
      "sqlcode": -204,
      "sqlstate": "42704",
      "message": "DB2SIM: no mapping configured for the requested statement"
    }
  }
