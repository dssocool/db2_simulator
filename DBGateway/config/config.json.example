{
  "backends": {
    // Configure db2 OR sqlServer, not both.
    "db2": {
      "host": "0.0.0.0",
      "port": 50000,
      "database": "TESTDB",
      "serverClassName": "QDB2/LINUXX8664",
      "serverName": "SIZZLINGDB",
      "productId": "SQL11055",
      "dataEndian": "little"
    }

    // SQL Server TDS simulator — replace the db2 block above with this (not both):
    //
    // "sqlServer": {
    //   "host": "0.0.0.0",
    //   "port": 11433,
    //   "database": "master",
    //   "serverName": "SIZZLINGDB",
    //   "productName": "Microsoft SQL Server",
    //   "productVersion": "16.00.4096"
    // }
  },
  "auth": {
    "requirePassword": true,
    "caseInsensitiveUser": true,
    "users": [
      { "user": "db2inst1", "password": "YourStrongPassword123" }
    ]
  },
  "trace": {
    "logCommands": true,
    "hexDump": false
  },
  "matching": {
    "ignoreCase": true,
    "collapseWhitespace": true,
    "trimTrailingSemicolon": true
  }
}
